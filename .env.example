# -------------------------------------------------------------------------
# Inkore Environment Variables Config (.env)
# -------------------------------------------------------------------------
# Note: Currently, Inkore is fully client-side and does not actively require these variables.
# They are documented here as part of the starter template and for future expansions
# (e.g., integrating Gemini for auto-moderation, spam analysis, or server-side routing).

# GEMINI_API_KEY: Required if Gemini AI API calls are added in the future.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used if self-referential links or OAuth integration are added.
APP_URL="https://inkore.vercel.app/"

# -------------------------------------------------------------------------
# Supabase (مُجهَّزة الآن، غير مُفعَّلة بعد)
# -------------------------------------------------------------------------
# التطبيق حاليًا لا يزال يعتمد بالكامل على localStorageAdapter.js — هذه
# المتغيرات مُجهَّزة مسبقًا فقط تحضيرًا للربط المستقبلي بـ Supabase (انظر
# src/utils/storage/supabaseAdapter.stub.js للتفاصيل الكاملة). NEXT_PUBLIC_
# البادئة ضرورية لأن @supabase/supabase-js يُستخدم من جهة العميل أيضًا.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
